# Frontend environment variables (safe, non-secret only)
# Copy this file to ".env" and adjust if needed.
#
# IMPORTANT: Never put API keys or secrets in the frontend.
# Only safe, non-secret config belongs here. The real backend is added later.

# Data source for the service layer.
#   mock    = use localStorage mock data (current phase, no backend needed)
#   backend = call the Spring Boot API (later phase)
VITE_API_MODE=mock

# Base URL of the backend API (only used when VITE_API_MODE=backend).
VITE_API_BASE_URL=http://localhost:8080/api
